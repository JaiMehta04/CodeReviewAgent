# Copy this file to .env and fill in your values.
# All variables use the CRA_ prefix.

# ── LLM Provider ──────────────────────────────────────────────
# Options: "groq" (free, recommended), "together", "openrouter",
#          "huggingface", "ollama" (local), or custom OpenAI-compatible
CRA_LLM_PROVIDER=groq

# ── Provider API Key ──────────────────────────────────────────
# Get free keys at:
#   Groq:       https://console.groq.com/keys
#   Together:   https://api.together.xyz/settings/api-keys
#   OpenRouter: https://openrouter.ai/keys
CRA_API_KEY=your_api_key_here

# ── Optional: Override model or base URL ──────────────────────
# CRA_API_MODEL=llama-3.3-70b-versatile      # Groq default
# CRA_API_BASE_URL=https://api.groq.com/openai/v1

# ── Ollama (local, no API key needed) ─────────────────────────
# CRA_LLM_PROVIDER=ollama
# CRA_OLLAMA_URL=http://localhost:11434
# CRA_OLLAMA_MODEL=qwen2.5-coder:7b

# ── HuggingFace (cloud, needs token) ─────────────────────────
# CRA_LLM_PROVIDER=huggingface
# CRA_HF_TOKEN=hf_your_token_here

# ── LLM Parameters ───────────────────────────────────────────
# CRA_TEMPERATURE=0.1
# CRA_MAX_TOKENS=4096
# CRA_TOP_P=0.95

# ── Agent Configuration ──────────────────────────────────────
# CRA_CONCURRENT_AGENTS=4
# CRA_AGENT_TIMEOUT_SECONDS=120
